      "parameters": {
        "jsCode": "let raw = $input.first().json.text;\nraw = raw.trim().replace(/^```json/i, '').replace(/```$/, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  parsed = { category: \"Other\", urgency: \"Medium\", location: \"Unknown\", description: raw };\n}\n\n// Generate a short, human-friendly case ID\nparsed.case_id = \"CF-\" + Math.floor(1000 + Math.random() * 9000);\n\nreturn [{ json: parsed }];"
      },
      "type": "n8n-nodes-base.code",
